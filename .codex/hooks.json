{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/feishu-stop-notify.js\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use_quality_check.mjs\"",
            "timeout": 60,
            "statusMessage": "Checking Codex-edited TypeScript files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/feishu-stop-notify.js\"",
            "timeout": 30,
            "statusMessage": "Sending Feishu notification"
          }
        ]
      }
    ]
  }
}
