DATABASE_URL="mysql://root:password@127.0.0.1:3306/saifute-wsm"
LEGACY_DATABASE_URL="mysql://root:password@127.0.0.1:3306/saifute"
APP_NAME=saifute-wms-server
NODE_ENV=development
API_GLOBAL_PREFIX=api
SWAGGER_ENABLED=true
SWAGGER_TITLE=saifute-wms-server API
SWAGGER_DESCRIPTION=Saifute WMS API documentation
SWAGGER_VERSION=0.1.0
SWAGGER_PATH=docs
SWAGGER_JSON_PATH=docs-json
JWT_SECRET=dev-secret
JWT_EXPIRES_IN_SECONDS=3600
SESSION_TTL_SECONDS=3600
SESSION_MAX_TTL_SECONDS=28800
SESSION_REFRESH_THRESHOLD_SECONDS=1200
CAPTCHA_TTL_SECONDS=300
CAPTCHA_ENABLED=true
PASSWORD_MAX_RETRIES=5
PASSWORD_LOCK_MINUTES=15
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=5000
LOG_LEVEL=debug
LOG_DIR=logs-dev
PORT=3000
