  materialCodeSnapshot String                    @db.VarChar(64)
  materialNameSnapshot String                    @db.VarChar(128)
  materialSpecSnapshot String?                   @db.VarChar(128)
  unitCodeSnapshot     String                    @db.VarChar(32)
  quantity             Decimal                   @db.Decimal(18, 6)
  unitPrice            Decimal                   @default(0) @db.Decimal(18, 2)
  amount               Decimal                   @default(0) @db.Decimal(18, 2)
  remark               String?                   @db.VarChar(500)
  createdBy            String?                   @db.VarChar(64)
  createdAt            DateTime                  @default(now())
  updatedBy            String?                   @db.VarChar(64)
  updatedAt            DateTime                  @updatedAt
  request              RdProcurementRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  material             Material                  @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  acceptanceLines      StockInOrderLine[]
  statusLedger         RdMaterialStatusLedger?
  statusHistories      RdMaterialStatusHistory[]

  @@unique([requestId, lineNo])
  @@index([materialId])
  @@map("rd_procurement_request_line")
}

model RdMaterialStatusLedger {
  id               Int                      @id @default(autoincrement())
  requestLineId    Int                      @unique
  pendingQty       Decimal                  @default(0) @db.Decimal(18, 6)
  inProcurementQty Decimal                  @default(0) @db.Decimal(18, 6)
  canceledQty      Decimal                  @default(0) @db.Decimal(18, 6)
  acceptedQty      Decimal                  @default(0) @db.Decimal(18, 6)
  handedOffQty     Decimal                  @default(0) @db.Decimal(18, 6)
  scrappedQty      Decimal                  @default(0) @db.Decimal(18, 6)
  returnedQty      Decimal                  @default(0) @db.Decimal(18, 6)
  lastEventAt      DateTime?
  createdBy        String?                  @db.VarChar(64)
  createdAt        DateTime                 @default(now())
  updatedBy        String?                  @db.VarChar(64)
  updatedAt        DateTime                 @updatedAt
  requestLine      RdProcurementRequestLine @relation(fields: [requestLineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("rd_material_status_ledger")
}

model RdMaterialStatusHistory {
  id                    Int                       @id @default(autoincrement())
  requestLineId         Int
  eventType             RdMaterialStatusEventType
  fromStatus            RdMaterialStatus?
  toStatus              RdMaterialStatus
  quantity              Decimal                   @db.Decimal(18, 6)
  sourceDocumentType    String?                   @db.VarChar(64)
  sourceDocumentId      Int?
  sourceDocumentLineId  Int?
  sourceDocumentNumber  String?                   @db.VarChar(64)
  referenceNo           String?                   @db.VarChar(128)
  reason                String?                   @db.VarChar(500)
  note                  String?                   @db.VarChar(500)
  relatedInventoryLogId Int?
  reversalOfHistoryId   Int?                      @unique
  isReversed            Boolean                   @default(false)
  reversedBy            String?                   @db.VarChar(64)
  reversedAt            DateTime?
  createdBy             String?                   @db.VarChar(64)
  createdAt             DateTime                  @default(now())
  requestLine           RdProcurementRequestLine  @relation(fields: [requestLineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  relatedInventoryLog   InventoryLog?             @relation(fields: [relatedInventoryLogId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reversalOfHistory     RdMaterialStatusHistory?  @relation("RdMaterialStatusHistoryReversal", fields: [reversalOfHistoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reversedByHistories   RdMaterialStatusHistory[] @relation("RdMaterialStatusHistoryReversal")

  @@index([requestLineId, createdAt])
  @@index([sourceDocumentType, sourceDocumentId])
  @@map("rd_material_status_history")
}

model RdStocktakeOrder {
  id                    Int                     @id @default(autoincrement())
  documentNo            String                  @unique @db.VarChar(64)
  bizDate               DateTime                @db.Date
  stockScopeId          Int?
  workshopId            Int
  lifecycleStatus       DocumentLifecycleStatus @default(EFFECTIVE)
  inventoryEffectStatus InventoryEffectStatus   @default(POSTED)
  auditStatusSnapshot   AuditStatusSnapshot     @default(NOT_REQUIRED)
  revisionNo            Int                     @default(1)
  countedBy             String?                 @db.VarChar(128)
  approvedBy            String?                 @db.VarChar(128)
  totalBookQty          Decimal                 @default(0) @db.Decimal(18, 6)
  totalCountQty         Decimal                 @default(0) @db.Decimal(18, 6)
  totalAdjustmentQty    Decimal                 @default(0) @db.Decimal(18, 6)
  remark                String?                 @db.VarChar(500)
  voidReason            String?                 @db.VarChar(500)
  voidedBy              String?                 @db.VarChar(64)
  voidedAt              DateTime?
  createdBy             String?                 @db.VarChar(64)
  createdAt             DateTime                @default(now())
  updatedBy             String?                 @db.VarChar(64)
  updatedAt             DateTime                @updatedAt
  stockScope            StockScope?             @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop              Workshop                @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lines                 RdStocktakeOrderLine[]

  @@index([bizDate])
  @@index([stockScopeId])
  @@index([workshopId])
  @@map("rd_stocktake_order")
}

model RdStocktakeOrderLine {
  id                   Int              @id @default(autoincrement())
  orderId              Int
  lineNo               Int
  materialId           Int
  rdProjectId          Int?
  materialCodeSnapshot String           @db.VarChar(64)
  materialNameSnapshot String           @db.VarChar(128)
  materialSpecSnapshot String?          @db.VarChar(128)
  unitCodeSnapshot     String           @db.VarChar(32)
  rdProjectCodeSnapshot String?         @db.VarChar(64)
  rdProjectNameSnapshot String?         @db.VarChar(128)
  bookQty              Decimal          @db.Decimal(18, 6)
  countedQty           Decimal          @db.Decimal(18, 6)
  adjustmentQty        Decimal          @db.Decimal(18, 6)
  inventoryLogId       Int?             @unique
  reason               String?          @db.VarChar(500)
  remark               String?          @db.VarChar(500)
  createdBy            String?          @db.VarChar(64)
  createdAt            DateTime         @default(now())
  updatedBy            String?          @db.VarChar(64)
  updatedAt            DateTime         @updatedAt
  order                RdStocktakeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  material             Material         @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rdProject            RdProject?       @relation(fields: [rdProjectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inventoryLog         InventoryLog?    @relation("RdStocktakeLineInventoryLog", fields: [inventoryLogId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([orderId, lineNo])
  @@unique([orderId, materialId, rdProjectId])
  @@index([materialId])
  @@index([rdProjectId])
  @@map("rd_stocktake_order_line")
}

model DocumentRelation {
  id                     Int                  @id @default(autoincrement())
  relationType           DocumentRelationType
  upstreamFamily         DocumentFamily
  upstreamDocumentType   String               @db.VarChar(64)
  upstreamDocumentId     Int
  downstreamFamily       DocumentFamily
  downstreamDocumentType String               @db.VarChar(64)
  downstreamDocumentId   Int
  isActive               Boolean              @default(true)
  createdBy              String?              @db.VarChar(64)
  createdAt              DateTime             @default(now())
  updatedBy              String?              @db.VarChar(64)
  updatedAt              DateTime             @updatedAt

  @@unique([relationType, upstreamFamily, upstreamDocumentId, downstreamFamily, downstreamDocumentId])
  @@index([upstreamFamily, upstreamDocumentId])
  @@index([downstreamFamily, downstreamDocumentId])
  @@map("document_relation")
}

model DocumentLineRelation {
  id                     Int                  @id @default(autoincrement())
  relationType           DocumentRelationType
  upstreamFamily         DocumentFamily
  upstreamDocumentType   String               @db.VarChar(64)
  upstreamDocumentId     Int
  upstreamLineId         Int
  downstreamFamily       DocumentFamily
  downstreamDocumentType String               @db.VarChar(64)
  downstreamDocumentId   Int
  downstreamLineId       Int
  linkedQty              Decimal              @db.Decimal(18, 6)
  createdBy              String?              @db.VarChar(64)
  createdAt              DateTime             @default(now())
  updatedBy              String?              @db.VarChar(64)
  updatedAt              DateTime             @updatedAt

  @@unique([relationType, upstreamFamily, upstreamLineId, downstreamFamily, downstreamLineId])
  @@index([upstreamFamily, upstreamDocumentId, upstreamLineId])
  @@index([downstreamFamily, downstreamDocumentId, downstreamLineId])
  @@map("document_line_relation")
}

model LoginLog {
  id         Int            @id @default(autoincrement())
  action     LoginLogAction
  username   String         @db.VarChar(64)
  userId     Int?
  sessionId  String?        @db.VarChar(64)
  ip         String?        @db.VarChar(64)
  userAgent  String?        @db.VarChar(500)
  result     LoginLogResult
  reason     String?        @db.VarChar(128)
  occurredAt DateTime       @default(now())

  @@index([action, result, occurredAt])
  @@index([username])
  @@index([occurredAt])
  @@map("sys_logininfor")
}

model OperLog {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(128)
  action       String        @db.VarChar(64)
  method       String        @db.VarChar(16)
  path         String        @db.VarChar(255)
  operatorId   Int?
  operatorName String?       @db.VarChar(64)
  ip           String?       @db.VarChar(64)
  userAgent    String?       @db.VarChar(500)
  requestData  String?       @db.LongText
  responseData String?       @db.LongText
  errorMessage String?       @db.LongText
  durationMs   Int
  status       OperLogStatus
  occurredAt   DateTime      @default(now())

  @@index([status, occurredAt])
  @@index([title, occurredAt])
  @@index([operatorName])
  @@map("sys_oper_log")
}

model SchedulerJob {
  id                Int                        @id @default(autoincrement())
  jobName           String                     @unique @db.VarChar(128)
  invokeTarget      String                     @db.VarChar(128)
  cronExpression    String                     @db.VarChar(64)
  status            SchedulerJobStatus         @default(ACTIVE)
  concurrencyPolicy SchedulerConcurrencyPolicy @default(FORBID)
  misfirePolicy     SchedulerMisfirePolicy     @default(FIRE_AND_PROCEED)
  remark            String?                    @db.VarChar(500)
  lastRunAt         DateTime?
  createdBy         String?                    @db.VarChar(64)
  createdAt         DateTime                   @default(now())
  updatedBy         String?                    @db.VarChar(64)
  updatedAt         DateTime                   @updatedAt
  logs              SchedulerJobLog[]

  @@index([status, updatedAt])
  @@index([invokeTarget])
  @@map("sys_job")
}

model SchedulerJobLog {
  id           Int                   @id @default(autoincrement())
  jobId        Int?
  jobName      String                @db.VarChar(128)
  invokeTarget String                @db.VarChar(128)
  status       SchedulerJobLogStatus
  message      String?               @db.LongText
  errorMessage String?               @db.LongText
  durationMs   Int
  startedAt    DateTime
  finishedAt   DateTime
  createdAt    DateTime              @default(now())
  schedulerJob SchedulerJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([jobId, startedAt])
  @@index([status, startedAt])
  @@index([jobName, startedAt])
  @@map("sys_job_log")
}

// ───── System Management Normalized Tables ─────

model SysDept {
  deptId    Int           @id @default(autoincrement()) @map("dept_id")
  parentId  Int           @default(0) @map("parent_id")
  ancestors String        @default("0") @db.VarChar(256)
  deptName  String        @map("dept_name") @db.VarChar(128)
  orderNum  Int           @default(0) @map("order_num")
  leader    String        @default("") @db.VarChar(64)
  phone     String        @default("") @db.VarChar(32)
  email     String        @default("") @db.VarChar(128)
  status    String        @default("0") @db.VarChar(1)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  users     SysUser[]
  roleDepts SysRoleDept[]

  @@index([parentId])
  @@map("sys_dept")
}

model SysPost {
  postId    Int           @id @default(autoincrement()) @map("post_id")
  postCode  String        @map("post_code") @db.VarChar(64)
  postName  String        @map("post_name") @db.VarChar(128)
  postSort  Int           @default(0) @map("post_sort")
  status    String        @default("0") @db.VarChar(1)
  remark    String        @default("") @db.VarChar(500)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  userPosts SysUserPost[]

  @@map("sys_post")
}

model SysMenu {
  menuId    Int           @id @default(autoincrement()) @map("menu_id")
  parentId  Int           @default(0) @map("parent_id")
  menuName  String        @map("menu_name") @db.VarChar(128)
  orderNum  Int           @default(0) @map("order_num")
  path      String        @default("") @db.VarChar(256)
  component String        @default("") @db.VarChar(256)
  routeName String        @default("") @map("route_name") @db.VarChar(128)
  menuType  String        @default("M") @map("menu_type") @db.VarChar(1)
  visible   String        @default("0") @db.VarChar(1)
  status    String        @default("0") @db.VarChar(1)
  perms     String        @default("") @db.VarChar(128)
  icon      String        @default("") @db.VarChar(128)
  query     String        @default("") @db.VarChar(256)
  isFrame   String        @default("1") @map("is_frame") @db.VarChar(1)
  isCache   String        @default("0") @map("is_cache") @db.VarChar(1)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  roleMenus SysRoleMenu[]

  @@index([parentId])
  @@map("sys_menu")
}

model SysRole {
  roleId            Int           @id @default(autoincrement()) @map("role_id")
  roleName          String        @map("role_name") @db.VarChar(128)
  roleKey           String        @unique @map("role_key") @db.VarChar(64)
  roleSort          Int           @default(0) @map("role_sort")
  status            String        @default("0") @db.VarChar(1)
  dataScope         String        @default("1") @map("data_scope") @db.VarChar(1)
  menuCheckStrictly Boolean       @default(true) @map("menu_check_strictly")
  deptCheckStrictly Boolean       @default(true) @map("dept_check_strictly")
  remark            String        @default("") @db.VarChar(500)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  userRoles         SysUserRole[]
  roleMenus         SysRoleMenu[]
  roleDepts         SysRoleDept[]

  @@map("sys_role")
}

model SysUser {
  userId           Int           @id @default(autoincrement()) @map("user_id")
  deptId           Int?          @map("dept_id")
  userName         String        @unique @map("user_name") @db.VarChar(64)
  nickName         String        @map("nick_name") @db.VarChar(64)
  avatarUrl        String?       @map("avatar_url") @db.VarChar(500)
  email            String        @default("") @db.VarChar(128)
  phonenumber      String        @default("") @db.VarChar(32)
  sex              String        @default("2") @db.VarChar(1)
  status           String        @default("0") @db.VarChar(1)
  deleted          Boolean       @default(false)
  remark           String        @default("") @db.VarChar(500)
  passwordHash     String        @map("password_hash") @db.VarChar(256)
  consoleMode      String        @default("default") @map("console_mode") @db.VarChar(32)
  stockScope       Json?         @map("stock_scope")
  workshopScope    Json?         @map("workshop_scope")
  extraPermissions Json?         @map("extra_permissions")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  dept             SysDept?      @relation(fields: [deptId], references: [deptId], onDelete: SetNull, onUpdate: Cascade)
  userRoles        SysUserRole[]
  userPosts        SysUserPost[]

  @@index([deptId])
  @@map("sys_user")
}

model SysDictType {
  dictId    Int           @id @default(autoincrement()) @map("dict_id")
  dictName  String        @map("dict_name") @db.VarChar(128)
  dictType  String        @unique @map("dict_type") @db.VarChar(64)
  status    String        @default("0") @db.VarChar(1)
  remark    String        @default("") @db.VarChar(500)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  dictItems SysDictData[]

  @@map("sys_dict_type")
}

model SysDictData {
  dictCode    Int         @id @default(autoincrement()) @map("dict_code")
  dictSort    Int         @default(0) @map("dict_sort")
  dictLabel   String      @map("dict_label") @db.VarChar(128)
  dictValue   String      @map("dict_value") @db.VarChar(128)
  dictType    String      @map("dict_type") @db.VarChar(64)
  cssClass    String      @default("") @map("css_class") @db.VarChar(64)
  listClass   String      @default("") @map("list_class") @db.VarChar(64)
  isDefault   String      @default("N") @map("is_default") @db.VarChar(1)
  status      String      @default("0") @db.VarChar(1)
  remark      String      @default("") @db.VarChar(500)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")
  dictTypeRef SysDictType @relation(fields: [dictType], references: [dictType], onDelete: Cascade, onUpdate: Cascade)

  @@index([dictType])
  @@map("sys_dict_data")
}

model SysConfig {
  configId    Int      @id @default(autoincrement()) @map("config_id")
  configName  String   @map("config_name") @db.VarChar(128)
  configKey   String   @unique @map("config_key") @db.VarChar(128)
  configValue String   @map("config_value") @db.VarChar(500)
  configType  String   @default("N") @map("config_type") @db.VarChar(1)
  remark      String   @default("") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sys_config")
}

model SysNotice {
  noticeId      Int      @id @default(autoincrement()) @map("notice_id")
  noticeTitle   String   @map("notice_title") @db.VarChar(256)
  noticeType    String   @default("1") @map("notice_type") @db.VarChar(1)
  noticeContent String   @map("notice_content") @db.LongText
  status        String   @default("0") @db.VarChar(1)
  remark        String   @default("") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sys_notice")
}

model SysUserRole {
  id     Int     @id @default(autoincrement())
  userId Int     @map("user_id")
  roleId Int     @map("role_id")
  user   SysUser @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("sys_user_role")
}

model SysUserPost {
  id     Int     @id @default(autoincrement())
  userId Int     @map("user_id")
  postId Int     @map("post_id")
  user   SysUser @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  post   SysPost @relation(fields: [postId], references: [postId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("sys_user_post")
}

model SysRoleMenu {
  id     Int     @id @default(autoincrement())
  roleId Int     @map("role_id")
  menuId Int     @map("menu_id")
  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: Cascade)
  menu   SysMenu @relation(fields: [menuId], references: [menuId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, menuId])
  @@index([menuId])
  @@map("sys_role_menu")
}

model SysRoleDept {
  id     Int     @id @default(autoincrement())
  roleId Int     @map("role_id")
  deptId Int     @map("dept_id")
  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: Cascade)
  dept   SysDept @relation(fields: [deptId], references: [deptId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, deptId])
  @@index([deptId])
  @@map("sys_role_dept")
}
