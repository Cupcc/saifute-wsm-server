generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum MasterDataStatus {
  ACTIVE
  DISABLED
}

enum DataCreationMode {
  MANUAL
  AUTO_CREATED
}

enum DocumentLifecycleStatus {
  EFFECTIVE
  VOIDED
}

enum AuditStatusSnapshot {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum InventoryEffectStatus {
  POSTED
  REVERSED
}

enum StockDirection {
  IN
  OUT
}

enum InventoryOperationType {
  ACCEPTANCE_IN
  PRODUCTION_RECEIPT_IN
  PRICE_CORRECTION_IN
  OUTBOUND_OUT
  PRICE_CORRECTION_OUT
  SUPPLIER_RETURN_OUT
  SALES_RETURN_IN
  PICK_OUT
  RETURN_IN
  SCRAP_OUT
  RD_PROJECT_OUT
  RD_HANDOFF_OUT
  RD_HANDOFF_IN
  RD_STOCKTAKE_IN
  RD_STOCKTAKE_OUT
  REVERSAL_IN
  REVERSAL_OUT
}

enum StockScopeType {
  MAIN
  RD_SUB
}

enum RdMaterialStatus {
  PENDING_PROCUREMENT
  IN_PROCUREMENT
  CANCELLED
  ACCEPTED
  HANDED_OFF
  SCRAPPED
  RETURNED
}

enum RdMaterialStatusEventType {
  REQUEST_CREATED
  PROCUREMENT_STARTED
  MANUAL_CANCELLED
  ACCEPTANCE_CONFIRMED
  HANDOFF_CONFIRMED
  SCRAP_CONFIRMED
  MANUAL_RETURNED
  FACT_ROLLBACK
  REQUEST_VOIDED
}

enum SourceUsageStatus {
  ALLOCATED
  PARTIALLY_RELEASED
  RELEASED
}

enum FactoryNumberReservationStatus {
  RESERVED
  RELEASED
  REVERSED
}

enum DocumentFamily {
  STOCK_IN
  SALES_STOCK
  WORKSHOP_MATERIAL
  RD_PROJECT
}

enum StockInOrderType {
  ACCEPTANCE
  PRODUCTION_RECEIPT
  SUPPLIER_RETURN
}

enum SalesStockOrderType {
  OUTBOUND
  SALES_RETURN
}

enum WorkshopMaterialOrderType {
  PICK
  RETURN
  SCRAP
}

enum RdProjectMaterialActionType {
  PICK
  RETURN
  SCRAP
}

enum DocumentRelationType {
  SALES_RETURN_FROM_OUTBOUND
  WORKSHOP_RETURN_FROM_PICK
  STOCK_IN_RETURN_TO_SUPPLIER
  REVERSAL_REFERENCE
  TRACEABILITY_REFERENCE
}

enum ProjectTargetType {
  RD_PROJECT
  SALES_PROJECT
  PRODUCTION_ORDER
  WORKSHOP_COMMON
  OFFICE_COMMON
}

enum LoginLogAction {
  LOGIN
  LOGOUT
}

enum LoginLogResult {
  SUCCESS
  FAILURE
}

enum OperLogStatus {
  SUCCESS
  FAILURE
}

enum SchedulerJobStatus {
  ACTIVE
  PAUSED
}

enum SchedulerConcurrencyPolicy {
  ALLOW
  FORBID
}

enum SchedulerMisfirePolicy {
  FIRE_AND_PROCEED
  SKIP
}

enum SchedulerJobLogStatus {
  SUCCESS
  FAILURE
}

model MaterialCategory {
  id           Int              @id @default(autoincrement())
  categoryCode String           @unique @map("category_code") @db.VarChar(64)
  categoryName String           @map("category_name") @db.VarChar(128)
  sortOrder    Int              @default(0) @map("sort_order")
  status       MasterDataStatus @default(ACTIVE)
  createdBy    String?          @map("created_by") @db.VarChar(64)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedBy    String?          @map("updated_by") @db.VarChar(64)
  updatedAt    DateTime         @updatedAt @map("updated_at")
  materials    Material[]

  @@map("material_category")
}

model Material {
  id                           Int                               @id @default(autoincrement())
  materialCode                 String                            @unique @map("material_code") @db.VarChar(64)
  materialName                 String                            @map("material_name") @db.VarChar(128)
  specModel                    String?                           @map("spec_model") @db.VarChar(128)
  categoryId                   Int?                              @map("category_id")
  unitCode                     String                            @map("unit_code") @db.VarChar(32)
  warningMinQty                Decimal?                          @map("warning_min_qty") @db.Decimal(18, 6)
  warningMaxQty                Decimal?                          @map("warning_max_qty") @db.Decimal(18, 6)
  status                       MasterDataStatus                  @default(ACTIVE)
  creationMode                 DataCreationMode                  @default(MANUAL) @map("creation_mode")
  sourceDocumentType           String?                           @map("source_document_type") @db.VarChar(64)
  sourceDocumentId             Int?                              @map("source_document_id")
  createdBy                    String?                           @map("created_by") @db.VarChar(64)
  createdAt                    DateTime                          @default(now()) @map("created_at")
  updatedBy                    String?                           @map("updated_by") @db.VarChar(64)
  updatedAt                    DateTime                          @updatedAt @map("updated_at")
  category                     MaterialCategory?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inventoryBalances            InventoryBalance[]
  inventoryLogs                InventoryLog[]
  inventorySourceUsages        InventorySourceUsage[]
  factoryNumberReservations    FactoryNumberReservation[]
  stockInOrderLines            StockInOrderLine[]
  stockInPriceCorrectionLines  StockInPriceCorrectionOrderLine[]
  salesStockOrderLines         SalesStockOrderLine[]
  salesProjectMaterialLines    SalesProjectMaterialLine[]
  workshopMaterialOrderLines   WorkshopMaterialOrderLine[]
  rdProjectMaterialLines       RdProjectMaterialLine[]
  rdProjectBomLines            RdProjectBomLine[]
  rdProjectMaterialActionLines RdProjectMaterialActionLine[]
  rdHandoffOrderLines          RdHandoffOrderLine[]
  rdProcurementRequestLines    RdProcurementRequestLine[]
  rdStocktakeOrderLines        RdStocktakeOrderLine[]
  monthlySnapshots             InventoryMonthlySnapshot[]

  @@index([categoryId])
  @@map("material")
}

model Customer {
  id                 Int               @id @default(autoincrement())
  customerCode       String            @unique @map("customer_code") @db.VarChar(64)
  customerName       String            @map("customer_name") @db.VarChar(128)
  contactPerson      String?           @map("contact_person") @db.VarChar(128)
  contactPhone       String?           @map("contact_phone") @db.VarChar(32)
  address            String?           @db.VarChar(255)
  parentId           Int?              @map("parent_id")
  status             MasterDataStatus  @default(ACTIVE)
  creationMode       DataCreationMode  @default(MANUAL) @map("creation_mode")
  sourceDocumentType String?           @map("source_document_type") @db.VarChar(64)
  sourceDocumentId   Int?              @map("source_document_id")
  createdBy          String?           @map("created_by") @db.VarChar(64)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedBy          String?           @map("updated_by") @db.VarChar(64)
  updatedAt          DateTime          @updatedAt @map("updated_at")
  parent             Customer?         @relation("CustomerTree", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children           Customer[]        @relation("CustomerTree")
  salesStockOrders   SalesStockOrder[]
  salesProjects      SalesProject[]
  rdProjects         RdProject[]

  @@index([parentId])
  @@map("customer")
}

model Supplier {
  id                    Int                    @id @default(autoincrement())
  supplierCode          String                 @unique @map("supplier_code") @db.VarChar(64)
  supplierName          String                 @map("supplier_name") @db.VarChar(128)
  supplierShortName     String?                @map("supplier_short_name") @db.VarChar(128)
  contactPerson         String?                @map("contact_person") @db.VarChar(128)
  contactPhone          String?                @map("contact_phone") @db.VarChar(32)
  address               String?                @db.VarChar(255)
  status                MasterDataStatus       @default(ACTIVE)
  creationMode          DataCreationMode       @default(MANUAL) @map("creation_mode")
  sourceDocumentType    String?                @map("source_document_type") @db.VarChar(64)
  sourceDocumentId      Int?                   @map("source_document_id")
  createdBy             String?                @map("created_by") @db.VarChar(64)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedBy             String?                @map("updated_by") @db.VarChar(64)
  updatedAt             DateTime               @updatedAt @map("updated_at")
  stockInOrders         StockInOrder[]
  rdProjects            RdProject[]
  rdProcurementRequests RdProcurementRequest[]

  @@map("supplier")
}

model Personnel {
  id                      Int                     @id @default(autoincrement())
  personnelName           String                  @map("personnel_name") @db.VarChar(128)
  contactPhone            String?                 @map("contact_phone") @db.VarChar(32)
  workshopId              Int?                    @map("workshop_id")
  status                  MasterDataStatus        @default(ACTIVE)
  createdBy               String?                 @map("created_by") @db.VarChar(64)
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedBy               String?                 @map("updated_by") @db.VarChar(64)
  updatedAt               DateTime                @updatedAt @map("updated_at")
  workshop                Workshop?               @relation("PersonnelWorkshop", fields: [workshopId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockInOrders           StockInOrder[]          @relation("StockInOrderHandler")
  salesStockOrders        SalesStockOrder[]       @relation("SalesStockOrderHandler")
  managedSalesProjects    SalesProject[]          @relation("SalesProjectManager")
  workshopMaterialOrders  WorkshopMaterialOrder[] @relation("WorkshopMaterialOrderHandler")
  defaultHandlerWorkshops Workshop[]              @relation("WorkshopDefaultHandler")
  managedRdProjects       RdProject[]             @relation("RdProjectManager")
  rdHandoffOrders         RdHandoffOrder[]        @relation("RdHandoffOrderHandler")
  rdProcurementRequests   RdProcurementRequest[]  @relation("RdProcurementRequestHandler")

  @@index([workshopId])
  @@map("personnel")
}

model Workshop {
  id                           Int                           @id @default(autoincrement())
  workshopName                 String                        @unique @map("workshop_name") @db.VarChar(128)
  defaultHandlerPersonnelId    Int?                          @map("default_handler_personnel_id")
  status                       MasterDataStatus              @default(ACTIVE)
  createdBy                    String?                       @map("created_by") @db.VarChar(64)
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedBy                    String?                       @map("updated_by") @db.VarChar(64)
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  inventoryLogs                InventoryLog[]
  factoryNumberReservations    FactoryNumberReservation[]
  stockInOrders                StockInOrder[]
  salesStockOrders             SalesStockOrder[]
  salesProjects                SalesProject[]
  stockInPriceCorrectionOrders StockInPriceCorrectionOrder[]
  workshopMaterialOrders       WorkshopMaterialOrder[]
  rdProjectMaterialActions     RdProjectMaterialAction[]
  defaultHandlerPersonnel      Personnel?                    @relation("WorkshopDefaultHandler", fields: [defaultHandlerPersonnelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rdProjects                   RdProject[]
  rdHandoffSourceOrders        RdHandoffOrder[]              @relation("RdHandoffSourceWorkshop")
  rdHandoffTargetOrders        RdHandoffOrder[]              @relation("RdHandoffTargetWorkshop")
  rdProcurementRequests        RdProcurementRequest[]
  rdStocktakeOrders            RdStocktakeOrder[]
  personnel                    Personnel[]                   @relation("PersonnelWorkshop")

  @@index([defaultHandlerPersonnelId])
  @@map("workshop")
}

model StockScope {
  id                           Int                           @id @default(autoincrement())
  scopeCode                    String                        @unique @map("scope_code") @db.VarChar(64)
  scopeName                    String                        @map("scope_name") @db.VarChar(128)
  scopeType                    StockScopeType                @default(MAIN) @map("scope_type")
  status                       MasterDataStatus              @default(ACTIVE)
  createdBy                    String?                       @map("created_by") @db.VarChar(64)
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedBy                    String?                       @map("updated_by") @db.VarChar(64)
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  inventoryBalances            InventoryBalance[]
  inventoryLogs                InventoryLog[]
  factoryNumberReservations    FactoryNumberReservation[]
  stockInOrders                StockInOrder[]
  salesStockOrders             SalesStockOrder[]
  salesProjects                SalesProject[]
  stockInPriceCorrectionOrders StockInPriceCorrectionOrder[]
  workshopMaterialOrders       WorkshopMaterialOrder[]
  rdProjectMaterialActions     RdProjectMaterialAction[]
  rdProjects                   RdProject[]
  rdHandoffSourceOrders        RdHandoffOrder[]              @relation("RdHandoffSourceStockScope")
  rdHandoffTargetOrders        RdHandoffOrder[]              @relation("RdHandoffTargetStockScope")
  rdProcurementRequests        RdProcurementRequest[]
  rdStocktakeOrders            RdStocktakeOrder[]
  monthlySnapshots             InventoryMonthlySnapshot[]

  @@map("stock_scope")
}

model InventoryBalance {
  id             Int            @id @default(autoincrement())
  materialId     Int            @map("material_id")
  stockScopeId   Int?           @map("stock_scope_id")
  quantityOnHand Decimal        @default(0) @map("quantity_on_hand") @db.Decimal(18, 6)
  rowVersion     Int            @default(0) @map("row_version")
  createdBy      String?        @map("created_by") @db.VarChar(64)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedBy      String?        @map("updated_by") @db.VarChar(64)
  updatedAt      DateTime       @updatedAt @map("updated_at")
  material       Material       @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope     StockScope?    @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  logs           InventoryLog[]

  @@unique([materialId, stockScopeId])
  @@index([stockScopeId])
  @@map("inventory_balance")
}

model ProjectTarget {
  id                 Int               @id @default(autoincrement())
  targetType         ProjectTargetType @map("target_type")
  targetCode         String            @unique @map("target_code") @db.VarChar(64)
  targetName         String            @map("target_name") @db.VarChar(128)
  sourceDocumentType String?           @map("source_document_type") @db.VarChar(64)
  sourceDocumentId   Int?              @map("source_document_id")
  isSystemDefault    Boolean           @default(false) @map("is_system_default")
  remark             String?           @db.VarChar(500)
  createdBy          String?           @map("created_by") @db.VarChar(64)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedBy          String?           @map("updated_by") @db.VarChar(64)
  updatedAt          DateTime          @updatedAt @map("updated_at")
  salesProject       SalesProject?
  rdProject          RdProject?
  inventoryLogs      InventoryLog[]

  @@unique([targetType, sourceDocumentType, sourceDocumentId])
  @@index([targetType])
  @@map("project_target")
}

model InventoryLog {
  id                         Int                              @id @default(autoincrement())
  balanceId                  Int                              @map("balance_id")
  materialId                 Int                              @map("material_id")
  stockScopeId               Int?                             @map("stock_scope_id")
  workshopId                 Int?                             @map("workshop_id")
  projectTargetId            Int?                             @map("project_target_id")
  bizDate                    DateTime                         @map("biz_date") @db.Date
  direction                  StockDirection
  operationType              InventoryOperationType           @map("operation_type")
  businessModule             String                           @map("business_module") @db.VarChar(64)
  businessDocumentType       String                           @map("business_document_type") @db.VarChar(64)
  businessDocumentId         Int                              @map("business_document_id")
  businessDocumentNumber     String                           @map("business_document_number") @db.VarChar(64)
  businessDocumentLineId     Int?                             @map("business_document_line_id")
  changeQty                  Decimal                          @map("change_qty") @db.Decimal(18, 6)
  beforeQty                  Decimal                          @map("before_qty") @db.Decimal(18, 6)
  afterQty                   Decimal                          @map("after_qty") @db.Decimal(18, 6)
  unitCost                   Decimal?                         @map("unit_cost") @db.Decimal(18, 2)
  costAmount                 Decimal?                         @map("cost_amount") @db.Decimal(18, 2)
  operatorId                 String?                          @map("operator_id") @db.VarChar(64)
  occurredAt                 DateTime                         @default(now()) @map("occurred_at")
  reversalOfLogId            Int?                             @unique @map("reversal_of_log_id")
  idempotencyKey             String                           @unique @map("idempotency_key") @db.VarChar(128)
  note                       String?                          @db.VarChar(500)
  balance                    InventoryBalance                 @relation(fields: [balanceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  material                   Material                         @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope                 StockScope?                      @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop                   Workshop?                        @relation(fields: [workshopId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  projectTarget              ProjectTarget?                   @relation(fields: [projectTargetId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reversalOfLog              InventoryLog?                    @relation("InventoryLogReversal", fields: [reversalOfLogId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reversedByLogs             InventoryLog[]                   @relation("InventoryLogReversal")
  allocatedSourceUsages      InventorySourceUsage[]
  sourcePriceCorrectionLine  StockInPriceCorrectionOrderLine? @relation("PriceCorrectionSourceInventoryLog")
  generatedOutCorrectionLine StockInPriceCorrectionOrderLine? @relation("PriceCorrectionGeneratedOutLog")
  generatedInCorrectionLine  StockInPriceCorrectionOrderLine? @relation("PriceCorrectionGeneratedInLog")
  rdMaterialStatusHistories  RdMaterialStatusHistory[]
  rdStocktakeOrderLine       RdStocktakeOrderLine?            @relation("RdStocktakeLineInventoryLog")

  @@index([balanceId])
  @@index([stockScopeId])
  @@index([projectTargetId])
  @@index([businessDocumentType, businessDocumentId])
  @@index([businessDocumentType, businessDocumentId, businessDocumentLineId])
  @@index([occurredAt])
  @@index([bizDate, direction])
  @@index([bizDate, operationType])
  @@index([stockScopeId, bizDate])
  @@index([workshopId, operationType, bizDate])
  @@map("inventory_log")
}

model InventorySourceUsage {
  id                   Int               @id @default(autoincrement())
  materialId           Int               @map("material_id")
  sourceLogId          Int               @map("source_log_id")
  consumerDocumentType String            @map("consumer_document_type") @db.VarChar(64)
  consumerDocumentId   Int               @map("consumer_document_id")
  consumerLineId       Int               @map("consumer_line_id")
  allocatedQty         Decimal           @map("allocated_qty") @db.Decimal(18, 6)
  releasedQty          Decimal           @default(0) @map("released_qty") @db.Decimal(18, 6)
  status               SourceUsageStatus @default(ALLOCATED)
  createdBy            String?           @map("created_by") @db.VarChar(64)
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedBy            String?           @map("updated_by") @db.VarChar(64)
  updatedAt            DateTime          @updatedAt @map("updated_at")
  material             Material          @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceLog            InventoryLog      @relation(fields: [sourceLogId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([consumerDocumentType, consumerLineId, sourceLogId])
  @@index([materialId])
  @@index([consumerDocumentType, consumerDocumentId])
  @@map("inventory_source_usage")
}

model InventoryMonthlySnapshot {
  id           Int    @id @default(autoincrement())
  yearMonth    String @map("year_month") @db.Char(7)
  materialId   Int    @map("material_id")
  stockScopeId Int?   @map("stock_scope_id")

  openingQty     Decimal @default(0) @map("opening_qty") @db.Decimal(18, 6)
  closingQty     Decimal @default(0) @map("closing_qty") @db.Decimal(18, 6)
  totalInQty     Decimal @default(0) @map("total_in_qty") @db.Decimal(18, 6)
  totalInAmount  Decimal @default(0) @map("total_in_amount") @db.Decimal(18, 2)
  totalOutQty    Decimal @default(0) @map("total_out_qty") @db.Decimal(18, 6)
  totalOutAmount Decimal @default(0) @map("total_out_amount") @db.Decimal(18, 2)

  snapshotAt DateTime    @default(now()) @map("snapshot_at")
  material   Material    @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope StockScope? @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([yearMonth, materialId, stockScopeId])
  @@index([yearMonth])
  @@index([stockScopeId, yearMonth])
  @@map("inventory_monthly_snapshot")
}

model FactoryNumberReservation {
  id                     Int                            @id @default(autoincrement())
  materialId             Int                            @map("material_id")
  stockScopeId           Int?                           @map("stock_scope_id")
  workshopId             Int?                           @map("workshop_id")
  businessDocumentType   String                         @map("business_document_type") @db.VarChar(64)
  businessDocumentId     Int                            @map("business_document_id")
  businessDocumentLineId Int                            @map("business_document_line_id")
  startNumber            String                         @map("start_number") @db.VarChar(64)
  endNumber              String                         @map("end_number") @db.VarChar(64)
  status                 FactoryNumberReservationStatus @default(RESERVED)
  reservedAt             DateTime                       @default(now()) @map("reserved_at")
  releasedAt             DateTime?                      @map("released_at")
  createdBy              String?                        @map("created_by") @db.VarChar(64)
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedBy              String?                        @map("updated_by") @db.VarChar(64)
  updatedAt              DateTime                       @updatedAt @map("updated_at")
  material               Material                       @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope             StockScope?                    @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop               Workshop?                      @relation(fields: [workshopId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([businessDocumentType, businessDocumentLineId, startNumber, endNumber])
  @@index([materialId, stockScopeId])
  @@index([materialId, workshopId])
  @@index([businessDocumentType, businessDocumentId])
  @@map("factory_number_reservation")
}

model ApprovalDocument {
  id             Int                 @id @default(autoincrement())
  documentFamily DocumentFamily      @map("document_family")
  documentType   String              @map("document_type") @db.VarChar(64)
  documentId     Int                 @map("document_id")
  documentNumber String              @map("document_number") @db.VarChar(64)
  auditStatus    AuditStatusSnapshot @default(PENDING) @map("audit_status")
  submittedBy    String?             @map("submitted_by") @db.VarChar(64)
  submittedAt    DateTime?           @map("submitted_at")
  decidedBy      String?             @map("decided_by") @db.VarChar(64)
  decidedAt      DateTime?           @map("decided_at")
  rejectReason   String?             @map("reject_reason") @db.VarChar(500)
  resetCount     Int                 @default(0) @map("reset_count")
  lastResetAt    DateTime?           @map("last_reset_at")
  createdBy      String?             @map("created_by") @db.VarChar(64)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedBy      String?             @map("updated_by") @db.VarChar(64)
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@unique([documentType, documentId])
  @@index([documentFamily, auditStatus])
  @@index([documentNumber])
  @@map("approval_document")
}

model StockInOrder {
  id                               Int                               @id @default(autoincrement())
  documentNo                       String                            @unique @map("document_no") @db.VarChar(64)
  orderType                        StockInOrderType                  @map("order_type")
  bizDate                          DateTime                          @map("biz_date") @db.Date
  salesProjectId                   Int?                              @map("sales_project_id")
  supplierId                       Int?                              @map("supplier_id")
  handlerPersonnelId               Int?                              @map("handler_personnel_id")
  stockScopeId                     Int?                              @map("stock_scope_id")
  workshopId                       Int?                              @map("workshop_id")
  rdProcurementRequestId           Int?                              @map("rd_procurement_request_id")
  lifecycleStatus                  DocumentLifecycleStatus           @default(EFFECTIVE) @map("lifecycle_status")
  auditStatusSnapshot              AuditStatusSnapshot               @default(PENDING) @map("audit_status_snapshot")
  inventoryEffectStatus            InventoryEffectStatus             @default(POSTED) @map("inventory_effect_status")
  revisionNo                       Int                               @default(1) @map("revision_no")
  salesProjectCodeSnapshot         String?                           @map("sales_project_code_snapshot") @db.VarChar(64)
  salesProjectNameSnapshot         String?                           @map("sales_project_name_snapshot") @db.VarChar(128)
  supplierCodeSnapshot             String?                           @map("supplier_code_snapshot") @db.VarChar(64)
  supplierNameSnapshot             String?                           @map("supplier_name_snapshot") @db.VarChar(128)
  handlerNameSnapshot              String?                           @map("handler_name_snapshot") @db.VarChar(128)
  workshopNameSnapshot             String?                           @map("workshop_name_snapshot") @db.VarChar(128)
  rdProcurementRequestNoSnapshot   String?                           @map("rd_procurement_request_no_snapshot") @db.VarChar(64)
  rdProcurementProjectCodeSnapshot String?                           @map("rd_procurement_project_code_snapshot") @db.VarChar(64)
  rdProcurementProjectNameSnapshot String?                           @map("rd_procurement_project_name_snapshot") @db.VarChar(128)
  totalQty                         Decimal                           @default(0) @map("total_qty") @db.Decimal(18, 6)
  totalAmount                      Decimal                           @default(0) @map("total_amount") @db.Decimal(18, 2)
  remark                           String?                           @db.VarChar(500)
