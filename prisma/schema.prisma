generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum MasterDataStatus {
  ACTIVE
  DISABLED
}

enum DataCreationMode {
  MANUAL
  AUTO_CREATED
}

enum DocumentLifecycleStatus {
  EFFECTIVE
  VOIDED
}

enum AuditStatusSnapshot {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum InventoryEffectStatus {
  POSTED
  REVERSED
}

enum StockDirection {
  IN
  OUT
}

enum InventoryOperationType {
  ACCEPTANCE_IN
  PRODUCTION_RECEIPT_IN
  PRICE_CORRECTION_IN
  OUTBOUND_OUT
  PRICE_CORRECTION_OUT
  SALES_RETURN_IN
  PICK_OUT
  RETURN_IN
  SCRAP_OUT
  RD_PROJECT_OUT
  RD_HANDOFF_OUT
  RD_HANDOFF_IN
  RD_STOCKTAKE_IN
  RD_STOCKTAKE_OUT
  REVERSAL_IN
  REVERSAL_OUT
}

enum StockScopeType {
  MAIN
  RD_SUB
}

enum RdMaterialStatus {
  PENDING_PROCUREMENT
  IN_PROCUREMENT
  CANCELLED
  ACCEPTED
  HANDED_OFF
  SCRAPPED
  RETURNED
}

enum RdMaterialStatusEventType {
  REQUEST_CREATED
  PROCUREMENT_STARTED
  MANUAL_CANCELLED
  ACCEPTANCE_CONFIRMED
  HANDOFF_CONFIRMED
  SCRAP_CONFIRMED
  MANUAL_RETURNED
  FACT_ROLLBACK
  REQUEST_VOIDED
}

enum SourceUsageStatus {
  ALLOCATED
  PARTIALLY_RELEASED
  RELEASED
}

enum FactoryNumberReservationStatus {
  RESERVED
  RELEASED
  REVERSED
}

enum DocumentFamily {
  STOCK_IN
  SALES_STOCK
  WORKSHOP_MATERIAL
  RD_PROJECT
}

enum StockInOrderType {
  ACCEPTANCE
  PRODUCTION_RECEIPT
}

enum SalesStockOrderType {
  OUTBOUND
  SALES_RETURN
}

enum WorkshopMaterialOrderType {
  PICK
  RETURN
  SCRAP
}

enum RdProjectMaterialActionType {
  PICK
  RETURN
  SCRAP
}

enum DocumentRelationType {
  SALES_RETURN_FROM_OUTBOUND
  WORKSHOP_RETURN_FROM_PICK
  REVERSAL_REFERENCE
  TRACEABILITY_REFERENCE
}

enum ProjectTargetType {
  RD_PROJECT
  SALES_PROJECT
  PRODUCTION_ORDER
  WORKSHOP_COMMON
  OFFICE_COMMON
}

enum LoginLogAction {
  LOGIN
  LOGOUT
}

enum LoginLogResult {
  SUCCESS
  FAILURE
}

enum OperLogStatus {
  SUCCESS
  FAILURE
}

enum SchedulerJobStatus {
  ACTIVE
  PAUSED
}

enum SchedulerConcurrencyPolicy {
  ALLOW
  FORBID
}

enum SchedulerMisfirePolicy {
  FIRE_AND_PROCEED
  SKIP
}

enum SchedulerJobLogStatus {
  SUCCESS
  FAILURE
}

model MaterialCategory {
  id           Int                @id @default(autoincrement())
  categoryCode String             @unique @db.VarChar(64)
  categoryName String             @db.VarChar(128)
  sortOrder    Int                @default(0)
  status       MasterDataStatus   @default(ACTIVE)
  createdBy    String?            @db.VarChar(64)
  createdAt    DateTime           @default(now())
  updatedBy    String?            @db.VarChar(64)
  updatedAt    DateTime           @updatedAt
  materials    Material[]

  @@map("material_category")
}

model Material {
  id                           Int                               @id @default(autoincrement())
  materialCode                 String                            @unique @db.VarChar(64)
  materialName                 String                            @db.VarChar(128)
  specModel                    String?                           @db.VarChar(128)
  categoryId                   Int?
  unitCode                     String                            @db.VarChar(32)
  warningMinQty                Decimal?                          @db.Decimal(18, 6)
  warningMaxQty                Decimal?                          @db.Decimal(18, 6)
  status                       MasterDataStatus                  @default(ACTIVE)
  creationMode                 DataCreationMode                  @default(MANUAL)
  sourceDocumentType           String?                           @db.VarChar(64)
  sourceDocumentId             Int?
  createdBy                    String?                           @db.VarChar(64)
  createdAt                    DateTime                          @default(now())
  updatedBy                    String?                           @db.VarChar(64)
  updatedAt                    DateTime                          @updatedAt
  category                     MaterialCategory?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inventoryBalances            InventoryBalance[]
  inventoryLogs                InventoryLog[]
  inventorySourceUsages        InventorySourceUsage[]
  factoryNumberReservations    FactoryNumberReservation[]
  stockInOrderLines            StockInOrderLine[]
  stockInPriceCorrectionLines  StockInPriceCorrectionOrderLine[]
  salesStockOrderLines         SalesStockOrderLine[]
  salesProjectMaterialLines    SalesProjectMaterialLine[]
  workshopMaterialOrderLines   WorkshopMaterialOrderLine[]
  rdProjectMaterialLines       RdProjectMaterialLine[]
  rdProjectBomLines            RdProjectBomLine[]
  rdProjectMaterialActionLines RdProjectMaterialActionLine[]
  rdHandoffOrderLines          RdHandoffOrderLine[]
  rdProcurementRequestLines    RdProcurementRequestLine[]
  rdStocktakeOrderLines        RdStocktakeOrderLine[]
  monthlySnapshots             InventoryMonthlySnapshot[]

  @@index([categoryId])
  @@map("material")
}

model Customer {
  id                 Int               @id @default(autoincrement())
  customerCode       String            @unique @db.VarChar(64)
  customerName       String            @db.VarChar(128)
  parentId           Int?
  status             MasterDataStatus  @default(ACTIVE)
  creationMode       DataCreationMode  @default(MANUAL)
  sourceDocumentType String?           @db.VarChar(64)
  sourceDocumentId   Int?
  createdBy          String?           @db.VarChar(64)
  createdAt          DateTime          @default(now())
  updatedBy          String?           @db.VarChar(64)
  updatedAt          DateTime          @updatedAt
  parent             Customer?         @relation("CustomerTree", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children           Customer[]        @relation("CustomerTree")
  salesStockOrders   SalesStockOrder[]
  salesProjects      SalesProject[]
  rdProjects         RdProject[]

  @@index([parentId])
  @@map("customer")
}

model Supplier {
  id                    Int                    @id @default(autoincrement())
  supplierCode          String                 @unique @db.VarChar(64)
  supplierName          String                 @db.VarChar(128)
  supplierShortName     String?                @db.VarChar(128)
  contactPerson         String?                @db.VarChar(128)
  contactPhone          String?                @db.VarChar(32)
  address               String?                @db.VarChar(255)
  status                MasterDataStatus       @default(ACTIVE)
  creationMode          DataCreationMode       @default(MANUAL)
  sourceDocumentType    String?                @db.VarChar(64)
  sourceDocumentId      Int?
  createdBy             String?                @db.VarChar(64)
  createdAt             DateTime               @default(now())
  updatedBy             String?                @db.VarChar(64)
  updatedAt             DateTime               @updatedAt
  stockInOrders         StockInOrder[]
  rdProjects            RdProject[]
  rdProcurementRequests RdProcurementRequest[]

  @@map("supplier")
}

model Personnel {
  id                      Int                     @id @default(autoincrement())
  personnelName           String                  @db.VarChar(128)
  contactPhone            String?                 @map("contact_phone") @db.VarChar(32)
  workshopId              Int?                    @map("workshop_id")
  status                  MasterDataStatus        @default(ACTIVE)
  createdBy               String?                 @db.VarChar(64)
  createdAt               DateTime                @default(now())
  updatedBy               String?                 @db.VarChar(64)
  updatedAt               DateTime                @updatedAt
  workshop                Workshop?               @relation("PersonnelWorkshop", fields: [workshopId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockInOrders           StockInOrder[]          @relation("StockInOrderHandler")
  salesStockOrders        SalesStockOrder[]       @relation("SalesStockOrderHandler")
  managedSalesProjects    SalesProject[]          @relation("SalesProjectManager")
  workshopMaterialOrders  WorkshopMaterialOrder[] @relation("WorkshopMaterialOrderHandler")
  defaultHandlerWorkshops Workshop[]              @relation("WorkshopDefaultHandler")
  managedRdProjects       RdProject[]             @relation("RdProjectManager")
  rdHandoffOrders         RdHandoffOrder[]        @relation("RdHandoffOrderHandler")
  rdProcurementRequests   RdProcurementRequest[]  @relation("RdProcurementRequestHandler")

  @@index([workshopId])
  @@map("personnel")
}

model Workshop {
  id                           Int                           @id @default(autoincrement())
  workshopName                 String                        @unique @db.VarChar(128)
  defaultHandlerPersonnelId    Int?                          @map("default_handler_personnel_id")
  status                       MasterDataStatus              @default(ACTIVE)
  createdBy                    String?                       @db.VarChar(64)
  createdAt                    DateTime                      @default(now())
  updatedBy                    String?                       @db.VarChar(64)
  updatedAt                    DateTime                      @updatedAt
  inventoryLogs                InventoryLog[]
  factoryNumberReservations    FactoryNumberReservation[]
  stockInOrders                StockInOrder[]
  salesStockOrders             SalesStockOrder[]
  salesProjects                SalesProject[]
  stockInPriceCorrectionOrders StockInPriceCorrectionOrder[]
  workshopMaterialOrders       WorkshopMaterialOrder[]
  rdProjectMaterialActions     RdProjectMaterialAction[]
  defaultHandlerPersonnel      Personnel?                    @relation("WorkshopDefaultHandler", fields: [defaultHandlerPersonnelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rdProjects                   RdProject[]
  rdHandoffSourceOrders        RdHandoffOrder[]              @relation("RdHandoffSourceWorkshop")
  rdHandoffTargetOrders        RdHandoffOrder[]              @relation("RdHandoffTargetWorkshop")
  rdProcurementRequests        RdProcurementRequest[]
  rdStocktakeOrders            RdStocktakeOrder[]
  personnel                    Personnel[]                   @relation("PersonnelWorkshop")

  @@index([defaultHandlerPersonnelId])
  @@map("workshop")
}

model StockScope {
  id                           Int                           @id @default(autoincrement())
  scopeCode                    String                        @unique @db.VarChar(64)
  scopeName                    String                        @db.VarChar(128)
  scopeType                    StockScopeType                @default(MAIN)
  status                       MasterDataStatus              @default(ACTIVE)
  createdBy                    String?                       @db.VarChar(64)
  createdAt                    DateTime                      @default(now())
  updatedBy                    String?                       @db.VarChar(64)
  updatedAt                    DateTime                      @updatedAt
  inventoryBalances            InventoryBalance[]
  inventoryLogs                InventoryLog[]
  factoryNumberReservations    FactoryNumberReservation[]
  stockInOrders                StockInOrder[]
  salesStockOrders             SalesStockOrder[]
  salesProjects                SalesProject[]
  stockInPriceCorrectionOrders StockInPriceCorrectionOrder[]
  workshopMaterialOrders       WorkshopMaterialOrder[]
  rdProjectMaterialActions     RdProjectMaterialAction[]
  rdProjects                   RdProject[]
  rdHandoffSourceOrders        RdHandoffOrder[]              @relation("RdHandoffSourceStockScope")
  rdHandoffTargetOrders        RdHandoffOrder[]              @relation("RdHandoffTargetStockScope")
  rdProcurementRequests        RdProcurementRequest[]
  rdStocktakeOrders            RdStocktakeOrder[]
  monthlySnapshots             InventoryMonthlySnapshot[]

  @@map("stock_scope")
}

model InventoryBalance {
  id             Int            @id @default(autoincrement())
  materialId     Int
  stockScopeId   Int?
  quantityOnHand Decimal        @default(0) @db.Decimal(18, 6)
  rowVersion     Int            @default(0)
  createdBy      String?        @db.VarChar(64)
  createdAt      DateTime       @default(now())
  updatedBy      String?        @db.VarChar(64)
  updatedAt      DateTime       @updatedAt
  material       Material       @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope     StockScope?    @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  logs           InventoryLog[]

  @@unique([materialId, stockScopeId])
  @@index([stockScopeId])
  @@map("inventory_balance")
}

model ProjectTarget {
  id                 Int               @id @default(autoincrement())
  targetType         ProjectTargetType
  targetCode         String            @unique @db.VarChar(64)
  targetName         String            @db.VarChar(128)
  sourceDocumentType String?           @db.VarChar(64)
  sourceDocumentId   Int?
  isSystemDefault    Boolean           @default(false)
  remark             String?           @db.VarChar(500)
  createdBy          String?           @db.VarChar(64)
  createdAt          DateTime          @default(now())
  updatedBy          String?           @db.VarChar(64)
  updatedAt          DateTime          @updatedAt
  salesProject       SalesProject?
  rdProject          RdProject?
  inventoryLogs      InventoryLog[]

  @@unique([targetType, sourceDocumentType, sourceDocumentId])
  @@index([targetType])
  @@map("project_target")
}

model InventoryLog {
  id                         Int                              @id @default(autoincrement())
  balanceId                  Int
  materialId                 Int
  stockScopeId               Int?
  workshopId                 Int?
  projectTargetId            Int?
  bizDate                    DateTime                         @db.Date
  direction                  StockDirection
  operationType              InventoryOperationType
  businessModule             String                           @db.VarChar(64)
  businessDocumentType       String                           @db.VarChar(64)
  businessDocumentId         Int
  businessDocumentNumber     String                           @db.VarChar(64)
  businessDocumentLineId     Int?
  changeQty                  Decimal                          @db.Decimal(18, 6)
  beforeQty                  Decimal                          @db.Decimal(18, 6)
  afterQty                   Decimal                          @db.Decimal(18, 6)
  unitCost                   Decimal?                         @db.Decimal(18, 2)
  costAmount                 Decimal?                         @db.Decimal(18, 2)
  operatorId                 String?                          @db.VarChar(64)
  occurredAt                 DateTime                         @default(now())
  reversalOfLogId            Int?                             @unique
  idempotencyKey             String                           @unique @db.VarChar(128)
  note                       String?                          @db.VarChar(500)
  balance                    InventoryBalance                 @relation(fields: [balanceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  material                   Material                         @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope                 StockScope?                      @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop                   Workshop?                        @relation(fields: [workshopId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  projectTarget              ProjectTarget?                   @relation(fields: [projectTargetId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reversalOfLog              InventoryLog?                    @relation("InventoryLogReversal", fields: [reversalOfLogId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reversedByLogs             InventoryLog[]                   @relation("InventoryLogReversal")
  allocatedSourceUsages      InventorySourceUsage[]
  sourcePriceCorrectionLine  StockInPriceCorrectionOrderLine? @relation("PriceCorrectionSourceInventoryLog")
  generatedOutCorrectionLine StockInPriceCorrectionOrderLine? @relation("PriceCorrectionGeneratedOutLog")
  generatedInCorrectionLine  StockInPriceCorrectionOrderLine? @relation("PriceCorrectionGeneratedInLog")
  rdMaterialStatusHistories  RdMaterialStatusHistory[]
  rdStocktakeOrderLine       RdStocktakeOrderLine?            @relation("RdStocktakeLineInventoryLog")

  @@index([balanceId])
  @@index([stockScopeId])
  @@index([projectTargetId])
  @@index([businessDocumentType, businessDocumentId])
  @@index([businessDocumentType, businessDocumentId, businessDocumentLineId])
  @@index([occurredAt])
  @@index([bizDate, direction])
  @@index([bizDate, operationType])
  @@index([stockScopeId, bizDate])
  @@index([workshopId, operationType, bizDate])
  @@map("inventory_log")
}

model InventorySourceUsage {
  id                   Int               @id @default(autoincrement())
  materialId           Int
  sourceLogId          Int
  consumerDocumentType String            @db.VarChar(64)
  consumerDocumentId   Int
  consumerLineId       Int
  allocatedQty         Decimal           @db.Decimal(18, 6)
  releasedQty          Decimal           @default(0) @db.Decimal(18, 6)
  status               SourceUsageStatus @default(ALLOCATED)
  createdBy            String?           @db.VarChar(64)
  createdAt            DateTime          @default(now())
  updatedBy            String?           @db.VarChar(64)
  updatedAt            DateTime          @updatedAt
  material             Material          @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceLog            InventoryLog      @relation(fields: [sourceLogId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([consumerDocumentType, consumerLineId, sourceLogId])
  @@index([materialId])
  @@index([consumerDocumentType, consumerDocumentId])
  @@map("inventory_source_usage")
}

model InventoryMonthlySnapshot {
  id           Int    @id @default(autoincrement())
  yearMonth    String @db.Char(7)
  materialId   Int
  stockScopeId Int?

  openingQty     Decimal @default(0) @db.Decimal(18, 6)
  closingQty     Decimal @default(0) @db.Decimal(18, 6)
  totalInQty     Decimal @default(0) @db.Decimal(18, 6)
  totalInAmount  Decimal @default(0) @db.Decimal(18, 2)
  totalOutQty    Decimal @default(0) @db.Decimal(18, 6)
  totalOutAmount Decimal @default(0) @db.Decimal(18, 2)

  snapshotAt DateTime    @default(now())
  material   Material    @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope StockScope? @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([yearMonth, materialId, stockScopeId])
  @@index([yearMonth])
  @@index([stockScopeId, yearMonth])
  @@map("inventory_monthly_snapshot")
}

model FactoryNumberReservation {
  id                     Int                            @id @default(autoincrement())
  materialId             Int
  stockScopeId           Int?
  workshopId             Int?
  businessDocumentType   String                         @db.VarChar(64)
  businessDocumentId     Int
  businessDocumentLineId Int
  startNumber            String                         @db.VarChar(64)
  endNumber              String                         @db.VarChar(64)
  status                 FactoryNumberReservationStatus @default(RESERVED)
  reservedAt             DateTime                       @default(now())
  releasedAt             DateTime?
  createdBy              String?                        @db.VarChar(64)
  createdAt              DateTime                       @default(now())
  updatedBy              String?                        @db.VarChar(64)
  updatedAt              DateTime                       @updatedAt
  material               Material                       @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockScope             StockScope?                    @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop               Workshop?                      @relation(fields: [workshopId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([businessDocumentType, businessDocumentLineId, startNumber, endNumber])
  @@index([materialId, stockScopeId])
  @@index([materialId, workshopId])
  @@index([businessDocumentType, businessDocumentId])
  @@map("factory_number_reservation")
}

model ApprovalDocument {
  id             Int                 @id @default(autoincrement())
  documentFamily DocumentFamily
  documentType   String              @db.VarChar(64)
  documentId     Int
  documentNumber String              @db.VarChar(64)
  auditStatus    AuditStatusSnapshot @default(PENDING)
  submittedBy    String?             @db.VarChar(64)
  submittedAt    DateTime?
  decidedBy      String?             @db.VarChar(64)
  decidedAt      DateTime?
  rejectReason   String?             @db.VarChar(500)
  resetCount     Int                 @default(0)
  lastResetAt    DateTime?
  createdBy      String?             @db.VarChar(64)
  createdAt      DateTime            @default(now())
  updatedBy      String?             @db.VarChar(64)
  updatedAt      DateTime            @updatedAt

  @@unique([documentType, documentId])
  @@index([documentFamily, auditStatus])
  @@index([documentNumber])
  @@map("approval_document")
}

model StockInOrder {
  id                               Int                               @id @default(autoincrement())
  documentNo                       String                            @unique @db.VarChar(64)
  orderType                        StockInOrderType
  bizDate                          DateTime                          @db.Date
  supplierId                       Int?
  handlerPersonnelId               Int?
  stockScopeId                     Int?
  workshopId                       Int?
  rdProcurementRequestId           Int?
  lifecycleStatus                  DocumentLifecycleStatus           @default(EFFECTIVE)
  auditStatusSnapshot              AuditStatusSnapshot               @default(PENDING)
  inventoryEffectStatus            InventoryEffectStatus             @default(POSTED)
  revisionNo                       Int                               @default(1)
  supplierCodeSnapshot             String?                           @db.VarChar(64)
  supplierNameSnapshot             String?                           @db.VarChar(128)
  handlerNameSnapshot              String?                           @db.VarChar(128)
  workshopNameSnapshot             String?                           @db.VarChar(128)
  rdProcurementRequestNoSnapshot   String?                           @db.VarChar(64)
  rdProcurementProjectCodeSnapshot String?                           @db.VarChar(64)
  rdProcurementProjectNameSnapshot String?                           @db.VarChar(128)
  totalQty                         Decimal                           @default(0) @db.Decimal(18, 6)
  totalAmount                      Decimal                           @default(0) @db.Decimal(18, 2)
  remark                           String?                           @db.VarChar(500)
  voidReason                       String?                           @db.VarChar(500)
  voidedBy                         String?                           @db.VarChar(64)
  voidedAt                         DateTime?
  createdBy                        String?                           @db.VarChar(64)
  createdAt                        DateTime                          @default(now())
  updatedBy                        String?                           @db.VarChar(64)
  updatedAt                        DateTime                          @updatedAt
  supplier                         Supplier?                         @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  handlerPersonnel                 Personnel?                        @relation("StockInOrderHandler", fields: [handlerPersonnelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockScope                       StockScope?                       @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop                         Workshop?                         @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rdProcurementRequest             RdProcurementRequest?             @relation(fields: [rdProcurementRequestId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  lines                            StockInOrderLine[]
  priceCorrectionLines             StockInPriceCorrectionOrderLine[] @relation("PriceCorrectionSourceStockInOrder")

  @@index([bizDate, orderType])
  @@index([supplierId])
  @@index([stockScopeId])
  @@index([workshopId])
  @@index([rdProcurementRequestId])
  @@map("stock_in_order")
}

model StockInOrderLine {
  id                         Int                               @id @default(autoincrement())
  orderId                    Int
  lineNo                     Int
  materialId                 Int
  rdProcurementRequestLineId Int?
  materialCategoryIdSnapshot Int?
  materialCategoryCodeSnapshot String?                        @db.VarChar(64)
  materialCategoryNameSnapshot String?                        @db.VarChar(128)
  materialCategoryPathSnapshot Json?
  materialCodeSnapshot       String                            @db.VarChar(64)
  materialNameSnapshot       String                            @db.VarChar(128)
  materialSpecSnapshot       String?                           @db.VarChar(128)
  unitCodeSnapshot           String                            @db.VarChar(32)
  quantity                   Decimal                           @db.Decimal(18, 6)
  unitPrice                  Decimal                           @default(0) @db.Decimal(18, 2)
  amount                     Decimal                           @default(0) @db.Decimal(18, 2)
  remark                     String?                           @db.VarChar(500)
  createdBy                  String?                           @db.VarChar(64)
  createdAt                  DateTime                          @default(now())
  updatedBy                  String?                           @db.VarChar(64)
  updatedAt                  DateTime                          @updatedAt
  order                      StockInOrder                      @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  material                   Material                          @relation(fields: [materialId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rdProcurementRequestLine   RdProcurementRequestLine?         @relation(fields: [rdProcurementRequestLineId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  priceCorrectionLines       StockInPriceCorrectionOrderLine[] @relation("PriceCorrectionSourceStockInOrderLine")

  @@unique([orderId, lineNo])
  @@index([materialId])
  @@index([rdProcurementRequestLineId])
  @@map("stock_in_order_line")
}

model SalesStockOrder {
  id                    Int                     @id @default(autoincrement())
  documentNo            String                  @unique @db.VarChar(64)
  orderType             SalesStockOrderType
  bizDate               DateTime                @db.Date
  customerId            Int?
  handlerPersonnelId    Int?
  stockScopeId          Int?
  workshopId            Int
  lifecycleStatus       DocumentLifecycleStatus @default(EFFECTIVE)
  auditStatusSnapshot   AuditStatusSnapshot     @default(PENDING)
  inventoryEffectStatus InventoryEffectStatus   @default(POSTED)
  revisionNo            Int                     @default(1)
  customerCodeSnapshot  String?                 @db.VarChar(64)
  customerNameSnapshot  String?                 @db.VarChar(128)
  handlerNameSnapshot   String?                 @db.VarChar(128)
  workshopNameSnapshot  String                  @db.VarChar(128)
  totalQty              Decimal                 @default(0) @db.Decimal(18, 6)
  totalAmount           Decimal                 @default(0) @db.Decimal(18, 2)
  remark                String?                 @db.VarChar(500)
  voidReason            String?                 @db.VarChar(500)
  voidedBy              String?                 @db.VarChar(64)
  voidedAt              DateTime?
  createdBy             String?                 @db.VarChar(64)
  createdAt             DateTime                @default(now())
  updatedBy             String?                 @db.VarChar(64)
  updatedAt             DateTime                @updatedAt
  customer              Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  handlerPersonnel      Personnel?              @relation("SalesStockOrderHandler", fields: [handlerPersonnelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stockScope            StockScope?             @relation(fields: [stockScopeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workshop              Workshop                @relation(fields: [workshopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lines                 SalesStockOrderLine[]

  @@index([bizDate, orderType])
  @@index([customerId])
  @@index([stockScopeId])
  @@index([workshopId])
  @@map("sales_stock_order")
}

model SalesStockOrderLine {
  id                       Int             @id @default(autoincrement())
  orderId                  Int
  lineNo                   Int
  materialId               Int
