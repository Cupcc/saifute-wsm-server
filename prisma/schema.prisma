  linkedQty              Decimal              @map("linked_qty") @db.Decimal(18, 6)
  createdBy              String?              @map("created_by") @db.VarChar(64)
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedBy              String?              @map("updated_by") @db.VarChar(64)
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@unique([relationType, upstreamFamily, upstreamLineId, downstreamFamily, downstreamLineId])
  @@index([upstreamFamily, upstreamDocumentId, upstreamLineId])
  @@index([downstreamFamily, downstreamDocumentId, downstreamLineId])
  @@map("document_line_relation")
}

model LoginLog {
  id         Int            @id @default(autoincrement())
  action     LoginLogAction
  username   String         @db.VarChar(64)
  userId     Int?           @map("user_id")
  sessionId  String?        @map("session_id") @db.VarChar(64)
  ip         String?        @db.VarChar(64)
  userAgent  String?        @map("user_agent") @db.VarChar(500)
  result     LoginLogResult
  reason     String?        @db.VarChar(128)
  occurredAt DateTime       @default(now()) @map("occurred_at")

  @@index([action, result, occurredAt])
  @@index([username])
  @@index([occurredAt])
  @@map("sys_logininfor")
}

model OperLog {
  id           Int           @id @default(autoincrement())
  title        String        @db.VarChar(128)
  action       String        @db.VarChar(64)
  method       String        @db.VarChar(16)
  path         String        @db.VarChar(255)
  operatorId   Int?          @map("operator_id")
  operatorName String?       @map("operator_name") @db.VarChar(64)
  ip           String?       @db.VarChar(64)
  userAgent    String?       @map("user_agent") @db.VarChar(500)
  requestData  String?       @map("request_data") @db.LongText
  responseData String?       @map("response_data") @db.LongText
  errorMessage String?       @map("error_message") @db.LongText
  durationMs   Int           @map("duration_ms")
  status       OperLogStatus
  occurredAt   DateTime      @default(now()) @map("occurred_at")

  @@index([status, occurredAt])
  @@index([title, occurredAt])
  @@index([operatorName])
  @@map("sys_oper_log")
}

model SchedulerJob {
  id                Int                        @id @default(autoincrement())
  jobName           String                     @unique @map("job_name") @db.VarChar(128)
  invokeTarget      String                     @map("invoke_target") @db.VarChar(128)
  cronExpression    String                     @map("cron_expression") @db.VarChar(64)
  status            SchedulerJobStatus         @default(ACTIVE)
  concurrencyPolicy SchedulerConcurrencyPolicy @default(FORBID) @map("concurrency_policy")
  misfirePolicy     SchedulerMisfirePolicy     @default(FIRE_AND_PROCEED) @map("misfire_policy")
  remark            String?                    @db.VarChar(500)
  lastRunAt         DateTime?                  @map("last_run_at")
  createdBy         String?                    @map("created_by") @db.VarChar(64)
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedBy         String?                    @map("updated_by") @db.VarChar(64)
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  logs              SchedulerJobLog[]

  @@index([status, updatedAt])
  @@index([invokeTarget])
  @@map("sys_job")
}

model SchedulerJobLog {
  id           Int                   @id @default(autoincrement())
  jobId        Int?                  @map("job_id")
  jobName      String                @map("job_name") @db.VarChar(128)
  invokeTarget String                @map("invoke_target") @db.VarChar(128)
  status       SchedulerJobLogStatus
  message      String?               @db.LongText
  errorMessage String?               @map("error_message") @db.LongText
  durationMs   Int                   @map("duration_ms")
  startedAt    DateTime              @map("started_at")
  finishedAt   DateTime              @map("finished_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  schedulerJob SchedulerJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([jobId, startedAt])
  @@index([status, startedAt])
  @@index([jobName, startedAt])
  @@map("sys_job_log")
}

// ───── System Management Normalized Tables ─────

model SysDept {
  deptId    Int           @id @default(autoincrement()) @map("dept_id")
  parentId  Int           @default(0) @map("parent_id")
  ancestors String        @default("0") @db.VarChar(256)
  deptName  String        @map("dept_name") @db.VarChar(128)
  orderNum  Int           @default(0) @map("order_num")
  leader    String        @default("") @db.VarChar(64)
  phone     String        @default("") @db.VarChar(32)
  email     String        @default("") @db.VarChar(128)
  status    String        @default("0") @db.VarChar(1)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  users     SysUser[]
  roleDepts SysRoleDept[]

  @@index([parentId])
  @@map("sys_dept")
}

model SysPost {
  postId    Int           @id @default(autoincrement()) @map("post_id")
  postCode  String        @map("post_code") @db.VarChar(64)
  postName  String        @map("post_name") @db.VarChar(128)
  postSort  Int           @default(0) @map("post_sort")
  status    String        @default("0") @db.VarChar(1)
  remark    String        @default("") @db.VarChar(500)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  userPosts SysUserPost[]

  @@map("sys_post")
}

model SysMenu {
  menuId    Int           @id @default(autoincrement()) @map("menu_id")
  parentId  Int           @default(0) @map("parent_id")
  menuName  String        @map("menu_name") @db.VarChar(128)
  orderNum  Int           @default(0) @map("order_num")
  path      String        @default("") @db.VarChar(256)
  component String        @default("") @db.VarChar(256)
  routeName String        @default("") @map("route_name") @db.VarChar(128)
  menuType  String        @default("M") @map("menu_type") @db.VarChar(1)
  visible   String        @default("0") @db.VarChar(1)
  status    String        @default("0") @db.VarChar(1)
  perms     String        @default("") @db.VarChar(128)
  icon      String        @default("") @db.VarChar(128)
  query     String        @default("") @db.VarChar(256)
  isFrame   String        @default("1") @map("is_frame") @db.VarChar(1)
  isCache   String        @default("0") @map("is_cache") @db.VarChar(1)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  roleMenus SysRoleMenu[]

  @@index([parentId])
  @@map("sys_menu")
}

model SysRole {
  roleId            Int           @id @default(autoincrement()) @map("role_id")
  roleName          String        @map("role_name") @db.VarChar(128)
  roleKey           String        @unique @map("role_key") @db.VarChar(64)
  roleSort          Int           @default(0) @map("role_sort")
  status            String        @default("0") @db.VarChar(1)
  dataScope         String        @default("1") @map("data_scope") @db.VarChar(1)
  menuCheckStrictly Boolean       @default(true) @map("menu_check_strictly")
  deptCheckStrictly Boolean       @default(true) @map("dept_check_strictly")
  remark            String        @default("") @db.VarChar(500)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  userRoles         SysUserRole[]
  roleMenus         SysRoleMenu[]
  roleDepts         SysRoleDept[]

  @@map("sys_role")
}

model SysUser {
  userId           Int           @id @default(autoincrement()) @map("user_id")
  deptId           Int?          @map("dept_id")
  userName         String        @unique @map("user_name") @db.VarChar(64)
  nickName         String        @map("nick_name") @db.VarChar(64)
  avatarUrl        String?       @map("avatar_url") @db.VarChar(500)
  email            String        @default("") @db.VarChar(128)
  phonenumber      String        @default("") @db.VarChar(32)
  sex              String        @default("2") @db.VarChar(1)
  status           String        @default("0") @db.VarChar(1)
  deleted          Boolean       @default(false)
  remark           String        @default("") @db.VarChar(500)
  passwordHash     String        @map("password_hash") @db.VarChar(256)
  consoleMode      String        @default("default") @map("console_mode") @db.VarChar(32)
  stockScope       Json?         @map("stock_scope")
  workshopScope    Json?         @map("workshop_scope")
  extraPermissions Json?         @map("extra_permissions")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  dept             SysDept?      @relation(fields: [deptId], references: [deptId], onDelete: SetNull, onUpdate: Cascade)
  userRoles        SysUserRole[]
  userPosts        SysUserPost[]

  @@index([deptId])
  @@map("sys_user")
}

model SysDictType {
  dictId    Int           @id @default(autoincrement()) @map("dict_id")
  dictName  String        @map("dict_name") @db.VarChar(128)
  dictType  String        @unique @map("dict_type") @db.VarChar(64)
  status    String        @default("0") @db.VarChar(1)
  remark    String        @default("") @db.VarChar(500)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  dictItems SysDictData[]

  @@map("sys_dict_type")
}

model SysDictData {
  dictCode    Int         @id @default(autoincrement()) @map("dict_code")
  dictSort    Int         @default(0) @map("dict_sort")
  dictLabel   String      @map("dict_label") @db.VarChar(128)
  dictValue   String      @map("dict_value") @db.VarChar(128)
  dictType    String      @map("dict_type") @db.VarChar(64)
  cssClass    String      @default("") @map("css_class") @db.VarChar(64)
  listClass   String      @default("") @map("list_class") @db.VarChar(64)
  isDefault   String      @default("N") @map("is_default") @db.VarChar(1)
  status      String      @default("0") @db.VarChar(1)
  remark      String      @default("") @db.VarChar(500)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")
  dictTypeRef SysDictType @relation(fields: [dictType], references: [dictType], onDelete: Cascade, onUpdate: Cascade)

  @@index([dictType])
  @@map("sys_dict_data")
}

model SysConfig {
  configId    Int      @id @default(autoincrement()) @map("config_id")
  configName  String   @map("config_name") @db.VarChar(128)
  configKey   String   @unique @map("config_key") @db.VarChar(128)
  configValue String   @map("config_value") @db.VarChar(500)
  configType  String   @default("N") @map("config_type") @db.VarChar(1)
  remark      String   @default("") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sys_config")
}

model SysNotice {
  noticeId      Int      @id @default(autoincrement()) @map("notice_id")
  noticeTitle   String   @map("notice_title") @db.VarChar(256)
  noticeType    String   @default("1") @map("notice_type") @db.VarChar(1)
  noticeContent String   @map("notice_content") @db.LongText
  status        String   @default("0") @db.VarChar(1)
  remark        String   @default("") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sys_notice")
}

model SysUserRole {
  id     Int     @id @default(autoincrement())
  userId Int     @map("user_id")
  roleId Int     @map("role_id")
  user   SysUser @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("sys_user_role")
}

model SysUserPost {
  id     Int     @id @default(autoincrement())
  userId Int     @map("user_id")
  postId Int     @map("post_id")
  user   SysUser @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  post   SysPost @relation(fields: [postId], references: [postId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("sys_user_post")
}

model SysRoleMenu {
  id     Int     @id @default(autoincrement())
  roleId Int     @map("role_id")
  menuId Int     @map("menu_id")
  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: Cascade)
  menu   SysMenu @relation(fields: [menuId], references: [menuId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, menuId])
  @@index([menuId])
  @@map("sys_role_menu")
}

model SysRoleDept {
  id     Int     @id @default(autoincrement())
  roleId Int     @map("role_id")
  deptId Int     @map("dept_id")
  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: Cascade)
  dept   SysDept @relation(fields: [deptId], references: [deptId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, deptId])
  @@index([deptId])
  @@map("sys_role_dept")
}
